<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Manage Projects — Admin Fortress</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="style.css">
  <link rel="stylesheet" href="/css/admin.style.css">
</head>
<body>
  <div id="preloader"><div class="loader-ring"></div></div>
  <div class="cursor-dot"></div>
  <div class="cursor-outline"></div>
  <canvas id="particles-canvas"></canvas>
  <div class="sidebar-overlay"></div>

  <div class="admin-wrapper">

    <!-- SIDEBAR -->
    <aside class="admin-sidebar">
      <div class="sidebar-header">
        <div class="sidebar-brand">SB.<small>Admin Fortress</small></div>
        <button class="sidebar-close"><i class="fas fa-times"></i></button>
      </div>
      <nav class="sidebar-nav">
        <div class="sidebar-section-title">Main</div>
        <a href="/admin/dashboard" class="sidebar-link"><i class="fas fa-chart-line"></i> Dashboard</a>
        <a href="admin-projects.html" class="sidebar-link active"><i class="fas fa-folder-open"></i> Projects <span class="badge-count">12</span></a>
        <a href="admin-inquiries.html" class="sidebar-link"><i class="fas fa-envelope"></i> Inquiries <span class="badge-count red">5</span></a>
        <div class="sidebar-section-title">Content</div>
        <a href="/blog" class="sidebar-link"><i class="fas fa-pen-fancy"></i> Blog Posts</a>
        <a href="#" class="sidebar-link"><i class="fas fa-image"></i> Media</a>
        <div class="sidebar-section-title">System</div>
        <a href="#" class="sidebar-link"><i class="fas fa-cog"></i> Settings</a>
        <a href="/" class="sidebar-link"><i class="fas fa-globe"></i> View Site</a>
      </nav>
      <div class="sidebar-footer">
        <div class="sidebar-user"><div class="sidebar-avatar">SB</div><div class="sidebar-user-info"><h5>Shivam B.</h5><span>● Online</span></div></div>
      </div>
    </aside>

    <!-- MAIN -->
    <main class="admin-main">
      <header class="admin-topbar">
        <div class="topbar-left">
          <button class="topbar-burger"><i class="fas fa-bars"></i></button>
          <div class="topbar-title">
            <h2>Manage Projects</h2>
            <p>Add, edit, or remove portfolio projects.</p>
          </div>
        </div>
        <div class="topbar-right">
          <span style="font-family:var(--font-mono); font-size:0.82rem; color:var(--green); font-weight:600;" id="realtime-clock"></span>
          <button class="topbar-btn"><i class="fas fa-bell"></i><span class="notification-dot"></span></button>
          <a href="/admin/login" class="topbar-btn" title="Logout"><i class="fas fa-sign-out-alt"></i></a>
        </div>
      </header>

      <div class="admin-content">

        <!-- ===== PROJECT TABLE ===== -->
        <div class="admin-table-wrapper reveal">
          <div class="admin-table-header">
            <h3><i class="fas fa-folder-open me-2 text-green"></i> All Projects (12)</h3>
            <button class="add-new-btn" data-open-modal>
              <i class="fas fa-plus"></i> Add New Project
            </button>
          </div>
          <div class="table-responsive-custom">
            <table class="table-admin">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Project Name</th>
                  <th>Category</th>
                  <th>Tech Stack</th>
                  <th>Status</th>
                  <th>Date</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td style="color:var(--text-muted); font-family:var(--font-mono);">01</td>
                  <td style="font-weight:600; color:var(--text);">AI Art Generator</td>
                  <td><span class="tech-tag" style="font-size:0.7rem;">Full Stack</span></td>
                  <td>
                    <span class="tech-tag" style="font-size:0.68rem;">Node.js</span>
                    <span class="tech-tag purple" style="font-size:0.68rem;">React</span>
                  </td>
                  <td><span class="status-badge active">Live</span></td>
                  <td><span class="time-badge">Oct 2024</span></td>
                  <td>
                    <div class="d-flex gap-2">
                      <button class="action-btn view" title="View"><i class="fas fa-eye"></i></button>
                      <button class="action-btn edit" title="Edit"><i class="fas fa-pen"></i></button>
                      <button class="action-btn delete" title="Delete"><i class="fas fa-trash"></i></button>
                    </div>
                  </td>
                </tr>
                <tr>
                  <td style="color:var(--text-muted); font-family:var(--font-mono);">02</td>
                  <td style="font-weight:600; color:var(--text);">REST API Microservice</td>
                  <td><span class="tech-tag cyan" style="font-size:0.7rem;">Backend</span></td>
                  <td>
                    <span class="tech-tag" style="font-size:0.68rem;">Express</span>
                    <span class="tech-tag orange" style="font-size:0.68rem;">MongoDB</span>
                  </td>
                  <td><span class="status-badge active">Live</span></td>
                  <td><span class="time-badge">Sep 2024</span></td>
                  <td>
                    <div class="d-flex gap-2">
                      <button class="action-btn view" title="View"><i class="fas fa-eye"></i></button>
                      <button class="action-btn edit" title="Edit"><i class="fas fa-pen"></i></button>
                      <button class="action-btn delete" title="Delete"><i class="fas fa-trash"></i></button>
                    </div>
                  </td>
                </tr>
                <tr>
                  <td style="color:var(--text-muted); font-family:var(--font-mono);">03</td>
                  <td style="font-weight:600; color:var(--text);">E-Commerce Platform</td>
                  <td><span class="tech-tag" style="font-size:0.7rem;">Full Stack</span></td>
                  <td>
                    <span class="tech-tag" style="font-size:0.68rem;">Node.js</span>
                    <span class="tech-tag purple" style="font-size:0.68rem;">Stripe</span>
                  </td>
                  <td><span class="status-badge pending">Dev</span></td>
                  <td><span class="time-badge">Aug 2024</span></td>
                  <td>
                    <div class="d-flex gap-2">
                      <button class="action-btn view" title="View"><i class="fas fa-eye"></i></button>
                      <button class="action-btn edit" title="Edit"><i class="fas fa-pen"></i></button>
                      <button class="action-btn delete" title="Delete"><i class="fas fa-trash"></i></button>
                    </div>
                  </td>
                </tr>
                <tr>
                  <td style="color:var(--text-muted); font-family:var(--font-mono);">04</td>
                  <td style="font-weight:600; color:var(--text);">CLI Task Manager</td>
                  <td><span class="tech-tag orange" style="font-size:0.7rem;">Open Source</span></td>
                  <td>
                    <span class="tech-tag" style="font-size:0.68rem;">Node.js</span>
                    <span class="tech-tag cyan" style="font-size:0.68rem;">Commander</span>
                  </td>
                  <td><span class="status-badge active">Live</span></td>
                  <td><span class="time-badge">Jul 2024</span></td>
                  <td>
                    <div class="d-flex gap-2">
                      <button class="action-btn view" title="View"><i class="fas fa-eye"></i></button>
                      <button class="action-btn edit" title="Edit"><i class="fas fa-pen"></i></button>
                      <button class="action-btn delete" title="Delete"><i class="fas fa-trash"></i></button>
                    </div>
                  </td>
                </tr>
                <tr>
                  <td style="color:var(--text-muted); font-family:var(--font-mono);">05</td>
                  <td style="font-weight:600; color:var(--text);">Real-Time Chat Engine</td>
                  <td><span class="tech-tag cyan" style="font-size:0.7rem;">Backend</span></td>
                  <td>
                    <span class="tech-tag" style="font-size:0.68rem;">Socket.io</span>
                    <span class="tech-tag orange" style="font-size:0.68rem;">MongoDB</span>
                  </td>
                  <td><span class="status-badge active">Live</span></td>
                  <td><span class="time-badge">Jun 2024</span></td>
                  <td>
                    <div class="d-flex gap-2">
                      <button class="action-btn view" title="View"><i class="fas fa-eye"></i></button>
                      <button class="action-btn edit" title="Edit"><i class="fas fa-pen"></i></button>
                      <button class="action-btn delete" title="Delete"><i class="fas fa-trash"></i></button>
                    </div>
                  </td>
                </tr>
                <tr>
                  <td style="color:var(--text-muted); font-family:var(--font-mono);">06</td>
                  <td style="font-weight:600; color:var(--text);">NPM Utility Package</td>
                  <td><span class="tech-tag orange" style="font-size:0.7rem;">Open Source</span></td>
                  <td>
                    <span class="tech-tag purple" style="font-size:0.68rem;">TypeScript</span>
                    <span class="tech-tag" style="font-size:0.68rem;">Jest</span>
                  </td>
                  <td><span class="status-badge active">Live</span></td>
                  <td><span class="time-badge">May 2024</span></td>
                  <td>
                    <div class="d-flex gap-2">
                      <button class="action-btn view" title="View"><i class="fas fa-eye"></i></button>
                      <button class="action-btn edit" title="Edit"><i class="fas fa-pen"></i></button>
                      <button class="action-btn delete" title="Delete"><i class="fas fa-trash"></i></button>
                    </div>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

      </div>
    </main>
  </div>

  <!-- ===== ADD PROJECT MODAL ===== -->
  <div class="admin-modal-backdrop">
    <div class="admin-modal">
      <div class="admin-modal-header">
        <h3><i class="fas fa-plus-circle text-green me-2"></i> Add New Project</h3>
        <button class="modal-close-btn" data-close-modal><i class="fas fa-times"></i></button>
      </div>
      <div class="admin-modal-body">
        <form>
          <div class="mb-3">
            <label class="form-label-custom">Project Name</label>
            <input type="text" class="form-control-custom" placeholder="My Awesome Project">
          </div>
          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <label class="form-label-custom">Category</label>
              <select class="form-select-custom">
                <option value="" disabled selected>Select category</option>
                <option>Full Stack</option>
                <option>Backend</option>
                <option>Open Source</option>
                <option>Frontend</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label-custom">Status</label>
              <select class="form-select-custom">
                <option value="" disabled selected>Select status</option>
                <option>Live</option>
                <option>In Development</option>
                <option>Archived</option>
              </select>
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label-custom">Tech Stack (comma-separated)</label>
            <input type="text" class="form-control-custom" placeholder="Node.js, React, MongoDB">
          </div>
          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <label class="form-label-custom">Live Demo URL</label>
              <input type="url" class="form-control-custom" placeholder="https://demo.example.com">
            </div>
            <div class="col-md-6">
              <label class="form-label-custom">GitHub URL</label>
              <input type="url" class="form-control-custom" placeholder="https://github.com/user/repo">
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label-custom">Description</label>
            <textarea class="form-control-custom" rows="4" placeholder="Describe the project..."></textarea>
          </div>
          <div class="mb-3">
            <label class="form-label-custom">Project Image</label>
            <div style="border:2px dashed var(--glass-border); border-radius:var(--radius); padding:40px; text-align:center; cursor:pointer; transition:var(--transition);" onmouseover="this.style.borderColor='var(--green)'" onmouseout="this.style.borderColor='var(--glass-border)'">
              <i class="fas fa-cloud-upload-alt" style="font-size:2rem; color:var(--text-muted); margin-bottom:12px; display:block;"></i>
              <span style="font-size:0.85rem; color:var(--text-muted);">Click to upload or drag & drop</span>
              <br><span style="font-size:0.75rem; color:var(--text-muted);">PNG, JPG up to 5MB</span>
            </div>
          </div>
        </form>
      </div>
      <div class="admin-modal-footer">
        <button class="btn-outline-subtle" data-close-modal style="padding:10px 24px;">Cancel</button>
        <button class="add-new-btn" data-close-modal><i class="fas fa-check"></i> Save Project</button>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/admin.js"></script>
</body>
</html>
