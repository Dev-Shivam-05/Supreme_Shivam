<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard — Admin Fortress</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap">

  <style>
    /* =============================================
       ADMIN DASHBOARD — ALL-IN-ONE STYLES
       ============================================= */

    :root {
      --bg-primary: #06060b;
      --bg-secondary: #0c0c15;
      --bg-tertiary: #10101c;
      --surface: rgba(255, 255, 255, 0.02);
      --surface-hover: rgba(255, 255, 255, 0.06);
      --glass: rgba(255, 255, 255, 0.025);
      --glass-border: rgba(255, 255, 255, 0.07);
      --green: #00ff88;
      --green-dark: #00cc6a;
      --green-glow: rgba(0, 255, 136, 0.2);
      --purple: #8b5cf6;
      --purple-dark: #7c3aed;
      --purple-glow: rgba(139, 92, 246, 0.2);
      --cyan: #06b6d4;
      --pink: #ec4899;
      --orange: #f97316;
      --yellow: #facc15;
      --red: #ef4444;
      --text: #e2e8f0;
      --text-secondary: #94a3b8;
      --text-muted: #475569;
      --font-body: 'Inter', sans-serif;
      --font-heading: 'Space Grotesk', sans-serif;
      --font-mono: 'JetBrains Mono', monospace;
      --radius: 16px;
      --radius-sm: 8px;
      --radius-lg: 24px;
      --transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    *,
    *::before,
    *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
      scrollbar-width: thin;
      scrollbar-color: var(--green) var(--bg-primary);
    }

    ::-webkit-scrollbar {
      width: 6px;
    }

    ::-webkit-scrollbar-track {
      background: var(--bg-primary);
    }

    ::-webkit-scrollbar-thumb {
      background: var(--green);
      border-radius: 10px;
    }

    body {
      font-family: var(--font-body);
      background: var(--bg-primary);
      color: var(--text);
      line-height: 1.7;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
    }

    ::selection {
      background: var(--green);
      color: var(--bg-primary);
    }

    a {
      text-decoration: none;
      color: inherit;
      transition: var(--transition);
    }

    img {
      max-width: 100%;
      display: block;
    }

    ul {
      list-style: none;
    }

    h1,
    h2,
    h3,
    h4,
    h5,
    h6 {
      font-family: var(--font-heading);
      line-height: 1.2;
      font-weight: 700;
    }

    /* ===== PRELOADER ===== */
    #preloader {
      position: fixed;
      inset: 0;
      z-index: 99999;
      background: var(--bg-primary);
      display: flex;
      align-items: center;
      justify-content: center;
      transition: opacity 0.6s, visibility 0.6s;
    }

    #preloader.hidden {
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
    }

    .loader-ring {
      width: 50px;
      height: 50px;
      border-radius: 50%;
      border: 3px solid transparent;
      border-top-color: var(--green);
      border-right-color: var(--purple);
      animation: spin 0.8s linear infinite;
    }

    @keyframes spin {
      to {
        transform: rotate(360deg)
      }
    }

    /* ===== CURSOR ===== */
    .cursor-dot,
    .cursor-outline {
      position: fixed;
      top: 0;
      left: 0;
      pointer-events: none;
      z-index: 99998;
      border-radius: 50%;
      transform: translate(-50%, -50%);
    }

    .cursor-dot {
      width: 6px;
      height: 6px;
      background: var(--green);
      transition: width 0.3s, height 0.3s;
    }

    .cursor-outline {
      width: 36px;
      height: 36px;
      border: 1.5px solid rgba(0, 255, 136, 0.3);
      transition: all 0.15s ease-out;
    }

    @media(max-width:1024px) {

      .cursor-dot,
      .cursor-outline {
        display: none !important;
      }
    }

    /* ===== PARTICLES ===== */
    #particles-canvas {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
    }

    /* ===== NOISE ===== */
    .noise-overlay {
      position: fixed;
      inset: 0;
      z-index: 1;
      pointer-events: none;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
      opacity: 0.4;
    }

    /* ===== LAYOUT ===== */
    .admin-wrapper {
      display: flex;
      min-height: 100vh;
      position: relative;
      z-index: 2;
    }

    /* ===== SIDEBAR ===== */
    .admin-sidebar {
      width: 280px;
      background: rgba(8, 8, 16, 0.97);
      backdrop-filter: blur(20px);
      border-right: 1px solid var(--glass-border);
      position: fixed;
      top: 0;
      left: 0;
      bottom: 0;
      z-index: 1000;
      display: flex;
      flex-direction: column;
      transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      overflow-y: auto;
      overflow-x: hidden;
    }

    .admin-sidebar::-webkit-scrollbar {
      width: 3px;
    }

    .admin-sidebar::-webkit-scrollbar-thumb {
      background: var(--green);
      border-radius: 10px;
    }

    .sidebar-header {
      padding: 24px 20px;
      border-bottom: 1px solid var(--glass-border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-shrink: 0;
    }

    .sidebar-brand {
      font-family: var(--font-heading);
      font-size: 1.4rem;
      font-weight: 800;
      background: linear-gradient(135deg, var(--green), var(--cyan));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .sidebar-brand small {
      display: block;
      font-size: 0.6rem;
      font-weight: 600;
      letter-spacing: 3px;
      text-transform: uppercase;
      -webkit-text-fill-color: var(--text-muted);
      margin-top: 2px;
    }

    .sidebar-close {
      display: none;
      background: none;
      border: none;
      color: var(--text-muted);
      font-size: 1.2rem;
      cursor: pointer;
      padding: 4px;
      transition: var(--transition);
    }

    .sidebar-close:hover {
      color: var(--green);
    }

    .sidebar-nav {
      padding: 16px 12px;
      flex: 1;
    }

    .sidebar-section-title {
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 3px;
      color: var(--text-muted);
      font-weight: 700;
      padding: 14px 14px 8px;
      margin-top: 6px;
    }

    .sidebar-link {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 11px 16px;
      border-radius: 12px;
      color: var(--text-secondary);
      font-size: 0.88rem;
      font-weight: 500;
      transition: var(--transition);
      margin-bottom: 2px;
      position: relative;
    }

    .sidebar-link::before {
      content: '';
      position: absolute;
      left: 0;
      top: 50%;
      transform: translateY(-50%);
      width: 3px;
      height: 0;
      background: var(--green);
      border-radius: 0 3px 3px 0;
      transition: height 0.3s;
    }

    .sidebar-link:hover {
      color: var(--text);
      background: rgba(255, 255, 255, 0.03);
    }

    .sidebar-link:hover::before {
      height: 55%;
    }

    .sidebar-link.active {
      color: var(--green);
      background: rgba(0, 255, 136, 0.06);
      font-weight: 600;
    }

    .sidebar-link.active::before {
      height: 55%;
    }

    .sidebar-link i {
      width: 20px;
      text-align: center;
      font-size: 0.92rem;
      flex-shrink: 0;
    }

    .sidebar-link .badge-count {
      margin-left: auto;
      background: var(--green);
      color: var(--bg-primary);
      font-size: 0.68rem;
      font-weight: 800;
      padding: 2px 9px;
      border-radius: 50px;
      min-width: 22px;
      text-align: center;
    }

    .sidebar-link .badge-count.red {
      background: var(--red);
      color: #fff;
    }

    .sidebar-footer {
      padding: 16px 12px;
      border-top: 1px solid var(--glass-border);
      flex-shrink: 0;
    }

    .sidebar-user {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 14px;
      border-radius: 12px;
      background: var(--glass);
      border: 1px solid var(--glass-border);
    }

    .sidebar-avatar {
      width: 40px;
      height: 40px;
      border-radius: 12px;
      background: linear-gradient(135deg, var(--green), var(--cyan));
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: 0.85rem;
      color: var(--bg-primary);
      flex-shrink: 0;
    }

    .sidebar-user-info h5 {
      font-size: 0.85rem;
      font-weight: 700;
      margin: 0;
      color: var(--text);
    }

    .sidebar-user-info span {
      font-size: 0.7rem;
      color: var(--green);
      font-weight: 500;
    }

    /* ===== MAIN AREA ===== */
    .admin-main {
      flex: 1;
      margin-left: 280px;
      min-height: 100vh;
      position: relative;
      z-index: 2;
      background: var(--bg-primary);
    }

    /* ===== TOPBAR ===== */
    .admin-topbar {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(6, 6, 11, 0.9);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--glass-border);
      padding: 14px 28px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .topbar-left {
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .topbar-burger {
      display: none;
      background: none;
      border: 1px solid var(--glass-border);
      color: var(--text);
      font-size: 1rem;
      cursor: pointer;
      padding: 8px 12px;
      border-radius: 10px;
      transition: var(--transition);
    }

    .topbar-burger:hover {
      border-color: var(--green);
      color: var(--green);
    }

    .topbar-title h2 {
      font-size: 1.25rem;
      font-weight: 700;
      margin: 0;
    }

    .topbar-title p {
      font-size: 0.75rem;
      color: var(--text-muted);
      margin: 0;
    }

    .topbar-right {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .topbar-btn {
      width: 40px;
      height: 40px;
      border-radius: 12px;
      background: var(--glass);
      border: 1px solid var(--glass-border);
      color: var(--text-secondary);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: var(--transition);
      position: relative;
      font-size: 0.9rem;
    }

    .topbar-btn:hover {
      border-color: var(--green);
      color: var(--green);
      box-shadow: 0 0 15px var(--green-glow);
    }

    .notification-dot {
      position: absolute;
      top: 8px;
      right: 8px;
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--red);
      border: 2px solid var(--bg-primary);
    }

    /* ===== MAIN CONTENT ===== */
    .admin-content {
      padding: 28px;
    }

    /* ===== STAT CARDS ===== */
    .stat-card {
      background: var(--glass);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius);
      padding: 24px;
      transition: var(--transition);
      position: relative;
      overflow: hidden;
      height: 100%;
    }

    .stat-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      opacity: 0;
      transition: opacity 0.4s;
    }

    .stat-card.card-green::before {
      background: linear-gradient(90deg, var(--green), var(--cyan));
    }

    .stat-card.card-purple::before {
      background: linear-gradient(90deg, var(--purple), #a78bfa);
    }

    .stat-card.card-cyan::before {
      background: linear-gradient(90deg, var(--cyan), #22d3ee);
    }

    .stat-card.card-orange::before {
      background: linear-gradient(90deg, var(--orange), #fb923c);
    }

    .stat-card:hover {
      transform: translateY(-5px);
      border-color: rgba(255, 255, 255, 0.1);
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4);
    }

    .stat-card:hover::before {
      opacity: 1;
    }

    .stat-card-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 18px;
    }

    .stat-icon {
      width: 50px;
      height: 50px;
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.15rem;
    }

    .stat-icon.green {
      background: var(--green-glow);
      color: var(--green);
    }

    .stat-icon.purple {
      background: var(--purple-glow);
      color: var(--purple);
    }

    .stat-icon.cyan {
      background: rgba(6, 182, 212, 0.15);
      color: var(--cyan);
    }

    .stat-icon.orange {
      background: rgba(249, 115, 22, 0.15);
      color: var(--orange);
    }

    .stat-trend {
      font-size: 0.75rem;
      font-weight: 700;
      padding: 4px 10px;
      border-radius: 50px;
      display: flex;
      align-items: center;
      gap: 4px;
    }

    .stat-trend.up {
      background: rgba(0, 255, 136, 0.1);
      color: var(--green);
    }

    .stat-trend.down {
      background: rgba(239, 68, 68, 0.1);
      color: var(--red);
    }

    .stat-number {
      font-family: var(--font-heading);
      font-size: 2.3rem;
      font-weight: 800;
      color: var(--text);
      margin-bottom: 4px;
      line-height: 1;
    }

    .stat-label {
      font-size: 0.78rem;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 1.5px;
      font-weight: 600;
    }

    /* Sparkline */
    .sparkline {
      margin-top: 18px;
      height: 45px;
      border-radius: 8px;
      position: relative;
      overflow: hidden;
      display: flex;
      align-items: flex-end;
      gap: 3px;
      padding: 0 4px;
    }

    .spark-bar {
      flex: 1;
      border-radius: 3px 3px 0 0;
      transition: height 1s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      height: 0;
    }

    .spark-bar.green {
      background: linear-gradient(to top, var(--green), rgba(0, 255, 136, 0.3));
    }

    .spark-bar.purple {
      background: linear-gradient(to top, var(--purple), rgba(139, 92, 246, 0.3));
    }

    .spark-bar.cyan {
      background: linear-gradient(to top, var(--cyan), rgba(6, 182, 212, 0.3));
    }

    .spark-bar.orange {
      background: linear-gradient(to top, var(--orange), rgba(249, 115, 22, 0.3));
    }

    /* ===== TABLE ===== */
    .table-card {
      background: var(--glass);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius);
      overflow: hidden;
    }

    .table-card-header {
      padding: 20px 24px;
      border-bottom: 1px solid var(--glass-border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 12px;
    }

    .table-card-header h3 {
      font-size: 1.05rem;
      font-weight: 700;
      margin: 0;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .dot-live {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--green);
      animation: dotPulse 2s infinite;
    }

    @keyframes dotPulse {

      0%,
      100% {
        opacity: 1;
        transform: scale(1)
      }

      50% {
        opacity: 0.4;
        transform: scale(0.8)
      }
    }

    .export-btn {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 8px 18px;
      border-radius: 10px;
      background: transparent;
      border: 1px solid var(--glass-border);
      color: var(--text-secondary);
      font-size: 0.8rem;
      font-weight: 600;
      cursor: pointer;
      transition: var(--transition);
      font-family: var(--font-body);
    }

    .export-btn:hover {
      border-color: var(--green);
      color: var(--green);
      box-shadow: 0 0 15px var(--green-glow);
    }

    .table-responsive-wrap {
      overflow-x: auto;
    }

    .table-responsive-wrap::-webkit-scrollbar {
      height: 4px;
    }

    .table-responsive-wrap::-webkit-scrollbar-thumb {
      background: var(--green);
      border-radius: 10px;
    }

    .admin-table {
      width: 100%;
      border-collapse: collapse;
    }

    .admin-table thead th {
      padding: 12px 24px;
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: var(--text-muted);
      font-weight: 700;
      border-bottom: 1px solid var(--glass-border);
      background: rgba(255, 255, 255, 0.01);
      text-align: left;
      white-space: nowrap;
    }

    .admin-table tbody tr {
      border-bottom: 1px solid rgba(255, 255, 255, 0.02);
      transition: var(--transition);
    }

    .admin-table tbody tr:hover {
      background: rgba(0, 255, 136, 0.015);
    }

    .admin-table tbody tr:last-child {
      border-bottom: none;
    }

    .admin-table tbody td {
      padding: 14px 24px;
      font-size: 0.85rem;
      color: var(--text-secondary);
      vertical-align: middle;
      white-space: nowrap;
    }

    .ip-badge {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: var(--cyan);
      background: rgba(6, 182, 212, 0.08);
      padding: 4px 12px;
      border-radius: 6px;
      border: 1px solid rgba(6, 182, 212, 0.1);
    }

    .page-badge {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: var(--text-secondary);
    }

    .time-badge {
      font-family: var(--font-mono);
      font-size: 0.78rem;
      color: var(--text-muted);
    }

    .country-flag {
      font-size: 1.1rem;
      margin-right: 6px;
    }

    /* Status */
    .status-pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 4px 14px;
      border-radius: 50px;
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .status-pill::before {
      content: '';
      width: 6px;
      height: 6px;
      border-radius: 50%;
    }

    .status-pill.active {
      background: rgba(0, 255, 136, 0.1);
      color: var(--green);
    }

    .status-pill.active::before {
      background: var(--green);
    }

    .status-pill.idle {
      background: rgba(250, 204, 21, 0.1);
      color: var(--yellow);
    }

    .status-pill.idle::before {
      background: var(--yellow);
    }

    .status-pill.left {
      background: rgba(148, 163, 184, 0.1);
      color: var(--text-muted);
    }

    .status-pill.left::before {
      background: var(--text-muted);
    }

    /* ===== VISITOR MAP ===== */
    .map-container {
      width: 100%;
      height: 380px;
      background: var(--glass);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius);
      position: relative;
      overflow: hidden;
    }

    .map-grid-bg {
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(255, 255, 255, 0.015) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.015) 1px, transparent 1px);
      background-size: 40px 40px;
    }

    .map-radials {
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 25% 40%, rgba(0, 255, 136, 0.04), transparent 50%),
        radial-gradient(circle at 75% 30%, rgba(139, 92, 246, 0.03), transparent 50%),
        radial-gradient(circle at 50% 70%, rgba(6, 182, 212, 0.03), transparent 50%);
    }

    .map-dot {
      position: absolute;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      z-index: 5;
    }

    .map-dot::after {
      content: '';
      position: absolute;
      inset: -6px;
      border-radius: 50%;
      border: 2px solid;
      animation: mapPulse 3s infinite;
      opacity: 0.3;
    }

    .map-dot.g {
      background: var(--green);
      box-shadow: 0 0 12px var(--green-glow);
    }

    .map-dot.g::after {
      border-color: var(--green);
    }

    .map-dot.p {
      background: var(--purple);
      box-shadow: 0 0 12px var(--purple-glow);
    }

    .map-dot.p::after {
      border-color: var(--purple);
      animation-delay: 0.5s;
    }

    .map-dot.c {
      background: var(--cyan);
      box-shadow: 0 0 12px rgba(6, 182, 212, 0.3);
    }

    .map-dot.c::after {
      border-color: var(--cyan);
      animation-delay: 1s;
    }

    .map-dot.o {
      background: var(--orange);
      box-shadow: 0 0 12px rgba(249, 115, 22, 0.3);
    }

    .map-dot.o::after {
      border-color: var(--orange);
      animation-delay: 1.5s;
    }

    .map-dot.pk {
      background: var(--pink);
      box-shadow: 0 0 12px rgba(236, 72, 153, 0.3);
    }

    .map-dot.pk::after {
      border-color: var(--pink);
      animation-delay: 2s;
    }

    @keyframes mapPulse {
      0% {
        transform: scale(0.8);
        opacity: 0.4
      }

      100% {
        transform: scale(2.5);
        opacity: 0
      }
    }

    .map-center-label {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      text-align: center;
      z-index: 10;
    }

    .map-center-label i {
      font-size: 3.5rem;
      color: var(--green);
      opacity: 0.12;
      margin-bottom: 12px;
      display: block;
    }

    .map-center-label span {
      font-family: var(--font-mono);
      font-size: 0.82rem;
      color: var(--text-muted);
      background: rgba(0, 0, 0, 0.4);
      padding: 6px 20px;
      border-radius: 50px;
      backdrop-filter: blur(6px);
    }

    .map-legend {
      position: absolute;
      bottom: 16px;
      right: 16px;
      display: flex;
      gap: 14px;
      z-index: 10;
      background: rgba(0, 0, 0, 0.4);
      backdrop-filter: blur(8px);
      padding: 10px 16px;
      border-radius: 10px;
      border: 1px solid var(--glass-border);
    }

    .map-legend-item {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 0.68rem;
      color: var(--text-muted);
    }

    .map-legend-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
    }

    /* ===== QUICK ACCESS GRID ===== */
    .quick-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 12px;
    }

    .quick-card {
      background: var(--glass);
      border: 1px solid var(--glass-border);
      border-radius: 14px;
      padding: 20px;
      text-align: center;
      cursor: pointer;
      transition: var(--transition);
      text-decoration: none;
      color: inherit;
      display: block;
    }

    .quick-card:hover {
      transform: translateY(-4px);
      border-color: rgba(0, 255, 136, 0.15);
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
      color: inherit;
    }

    .quick-card i {
      font-size: 1.5rem;
      margin-bottom: 10px;
      display: block;
      transition: var(--transition);
    }

    .quick-card:hover i {
      transform: scale(1.15);
    }

    .quick-card span {
      font-size: 0.82rem;
      font-weight: 600;
      color: var(--text-secondary);
    }

    /* ===== ANIMATIONS ===== */
    .reveal {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.7s, transform 0.7s;
    }

    .reveal.active {
      opacity: 1;
      transform: translateY(0);
    }

    .reveal-d1 {
      transition-delay: 0.1s;
    }

    .reveal-d2 {
      transition-delay: 0.2s;
    }

    .reveal-d3 {
      transition-delay: 0.3s;
    }

    .reveal-d4 {
      transition-delay: 0.4s;
    }

    /* ===== SIDEBAR OVERLAY ===== */
    .sidebar-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.6);
      z-index: 999;
      opacity: 0;
      visibility: hidden;
      transition: var(--transition);
    }

    .sidebar-overlay.open {
      opacity: 1;
      visibility: visible;
    }

    /* ===== RESPONSIVE ===== */
    @media(max-width:1024px) {
      .admin-sidebar {
        transform: translateX(-100%);
      }

      .admin-sidebar.open {
        transform: translateX(0);
      }

      .sidebar-close {
        display: block;
      }

      .topbar-burger {
        display: flex;
      }

      .admin-main {
        margin-left: 0;
      }
    }

    @media(max-width:768px) {
      .admin-content {
        padding: 16px;
      }

      .admin-topbar {
        padding: 12px 16px;
      }

      .stat-number {
        font-size: 1.8rem;
      }

      .map-container {
        height: 260px;
      }

      .map-legend {
        display: none;
      }
    }

    @media(max-width:480px) {
      .topbar-title h2 {
        font-size: 1rem;
      }

      .topbar-title p {
        display: none;
      }
    }

    /* ===== GRADIENT TEXT ===== */
    .gradient-text {
      background: linear-gradient(135deg, var(--green), var(--cyan));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .text-green {
      color: var(--green) !important;
    }

    .text-purple {
      color: var(--purple) !important;
    }

    .text-cyan {
      color: var(--cyan) !important;
    }

    .text-orange {
      color: var(--orange) !important;
    }

    /* ===== SECTION HEADERS ===== */
    .section-header {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 20px;
    }

    .section-header .dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--green);
      animation: dotPulse 2s infinite;
    }

    .section-header span {
