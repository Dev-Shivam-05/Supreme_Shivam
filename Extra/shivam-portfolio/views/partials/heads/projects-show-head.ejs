<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/devicons/devicon@v2.15.1/devicon.min.css">
<style>
    /* ===== PROJECT SINGLE ENHANCEMENTS ===== */

    /* Hero Banner */
    .project-hero {
        position: relative;
        padding: 180px 0 80px;
        overflow: hidden;
    }

    .project-hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
            radial-gradient(ellipse at 30% 20%, rgba(0, 255, 136, 0.06) 0%, transparent 60%),
            radial-gradient(ellipse at 70% 80%, rgba(139, 92, 246, 0.05) 0%, transparent 60%);
    }

    .project-hero-banner {
        width: 100%;
        height: 450px;
        border-radius: 24px;
        background: linear-gradient(135deg, var(--bg-tertiary) 0%, var(--bg-secondary) 50%, rgba(0, 255, 136, 0.02) 100%);
        border: 1px solid var(--glass-border);
        overflow: hidden;
        position: relative;
        box-shadow: 0 30px 80px rgba(0, 0, 0, 0.5);
    }

    .browser-chrome {
        height: 40px;
        background: rgba(0, 0, 0, 0.3);
        border-bottom: 1px solid var(--glass-border);
        display: flex;
        align-items: center;
        padding: 0 20px;
        gap: 6px;
        position: relative;
        z-index: 2;
    }

    .browser-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
    }

    .browser-dot.r {
        background: #ff5f57;
    }

    .browser-dot.y {
        background: #ffbd2e;
    }

    .browser-dot.g {
        background: #28c840;
    }

    .browser-url {
        flex: 1;
        margin-left: 20px;
        display: flex;
        align-items: center;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.08);
        padding: 6px 12px;
        border-radius: 8px;
        font-family: var(--font-mono);
        font-size: 0.7rem;
        color: var(--text-muted);
        gap: 6px;
    }

    .browser-url i {
        color: var(--green);
        font-size: 0.6rem;
    }

    /* Screenshot mockup area */
    .screenshot-area {
        position: absolute;
        top: 42px;
        left: 0;
        right: 0;
        bottom: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 0;
    }

    .screenshot-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
        padding: 30px;
        width: 90%;
        max-width: 600px;
        opacity: 0.15;
    }

    .mock-card {
        height: 80px;
        border-radius: 10px;
        background: linear-gradient(135deg, rgba(0, 255, 136, 0.1), rgba(139, 92, 246, 0.1));
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .mock-card:nth-child(1) {
        grid-column: span 2;
        height: 100px;
    }

    .mock-card:nth-child(4) {
        grid-column: span 2;
    }

    .screenshot-label {
        position: absolute;
        bottom: 60px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 3;
        text-align: center;
    }

    .screenshot-label i {
        font-size: 3rem;
        color: var(--green);
        opacity: 0.15;
        margin-bottom: 12px;
        display: block;
    }

    .screenshot-label span {
        font-family: var(--font-mono);
        font-size: 0.8rem;
        color: var(--text-muted);
        background: rgba(0, 0, 0, 0.5);
        padding: 6px 20px;
        border-radius: 50px;
        backdrop-filter: blur(10px);
    }

    /* Project Title Area */
    .project-title-area {
        margin-top: -60px;
        position: relative;
        z-index: 5;
    }

    .project-icon-badge {
        width: 70px;
        height: 70px;
        border-radius: 20px;
        background: linear-gradient(135deg, var(--green-glow), rgba(139, 92, 246, 0.15));
        border: 2px solid rgba(0, 255, 136, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.6rem;
        color: var(--green);
        margin-bottom: 20px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
    }

    .project-main-title {
        font-size: clamp(2rem, 5vw, 3.2rem);
        font-weight: 900;
        margin-bottom: 12px;
    }

    .project-tagline {
        font-size: 1.1rem;
        color: var(--text-secondary);
        max-width: 650px;
        line-height: 1.7;
        margin-bottom: 24px;
    }

    .project-tags-row {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 20px;
    }

    /* Quick Stats Cards */
    .quick-stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 16px;
        margin: 50px 0;
    }

    .qs-card {
        background: var(--glass);
        border: 1px solid var(--glass-border);
        border-radius: 16px;
        padding: 24px;
        text-align: center;
        transition: var(--transition);
        position: relative;
        overflow: hidden;
    }

    .qs-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(90deg, transparent, var(--green), transparent);
        opacity: 0;
        transition: opacity 0.4s;
    }

    .qs-card:hover {
        transform: translateY(-4px);
        border-color: rgba(0, 255, 136, 0.15);
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.3);
    }

    .qs-card:hover::before {
        opacity: 1;
    }

    .qs-icon {
        width: 44px;
        height: 44px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        margin: 0 auto 12px;
        background: rgba(0, 255, 136, 0.1);
        color: var(--green);
    }

    .qs-title {
        font-size: 0.85rem;
        font-family: var(--font-mono);
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--text-muted);
        margin-bottom: 6px;
    }

    .qs-value {
        font-size: 1.1rem;
        font-weight: 700;
    }

    /* Problem & Solution */
    .problem-solution {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 30px;
        margin: 50px 0;
    }

    .ps-card {
        background: var(--glass);
        border: 1px solid var(--glass-border);
        border-radius: 20px;
        padding: 32px;
        transition: var(--transition);
        position: relative;
        overflow: hidden;
    }

    .ps-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(90deg, transparent, var(--green), transparent);
        opacity: 0;
        transition: opacity 0.4s;
    }

    .ps-card:hover {
        transform: translateY(-6px);
        border-color: rgba(0, 255, 136, 0.15);
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
    }

    .ps-card:hover::before {
        opacity: 1;
    }

    .ps-title {
        font-size: 1.1rem;
        font-weight: 800;
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .ps-title i {
        width: 36px;
        height: 36px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        background: rgba(0, 255, 136, 0.1);
        color: var(--green);
    }

    .ps-desc {
        font-size: 0.92rem;
        color: var(--text-secondary);
        line-height: 1.7;
    }

    /* Code Window */
    .code-window {
        background: var(--bg-secondary);
        border: 1px solid var(--glass-border);
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4);
    }

    .code-titlebar {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 12px 16px;
        border-bottom: 1px solid var(--glass-border);
        background: rgba(0, 0, 0, 0.4);
    }

    .code-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
    }

    .code-dot.red {
        background: #ff5f57;
    }

    .code-dot.yellow {
        background: #ffbd2e;
    }

    .code-dot.green {
        background: #28c840;
    }

    .code-filename {
        margin-left: 12px;
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--text-muted);
    }

    .code-body {
        font-family: var(--font-mono);
        font-size: 0.78rem;
        line-height: 1.6;
        padding: 20px;
        color: var(--text);
        background: rgba(0, 0, 0, 0.3);
        overflow-x: auto;
    }

    .code-body .line-num {
        color: var(--text-muted);
        display: inline-block;
        width: 24px;
    }

    .code-body .kw {
        color: var(--green);
    }

    .code-body .fn {
        color: var(--cyan);
    }

    .code-body .str {
        color: var(--orange);
    }

    .code-body .num {
        color: var(--purple);
    }

    .code-body .cm {
        color: var(--text-muted);
    }
</style>
